-- =========================================
-- Employee Management System
-- Triggers and Cursors in MySQL
-- =========================================

-- Create Database
CREATE DATABASE EmployeeDB;

-- Use Database
USE EmployeeDB;

-- =========================================
-- 1. CREATE EMPLOYEE TABLE
-- =========================================

CREATE TABLE Employees (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    department VARCHAR(30),
    salary DECIMAL(10,2)
);

-- =========================================
-- 2. CREATE AUDIT TABLE
-- =========================================

CREATE TABLE Employee_Audit (
    audit_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT,
    action_type VARCHAR(10),
    old_salary DECIMAL(10,2),
    new_salary DECIMAL(10,2),
    action_date DATETIME
);

-- =========================================
-- 3. INSERT SAMPLE DATA
-- =========================================

INSERT INTO Employees VALUES
(101, 'Aditya', 'IT', 50000),
(102, 'Rahul', 'HR', 40000),
(103, 'Sneha', 'IT', 55000),
(104, 'Aman', 'Finance', 45000);

-- =========================================
-- 4. TRIGGER FOR INSERT
-- =========================================

DELIMITER $$

CREATE TRIGGER trg_employee_insert
AFTER INSERT ON Employees
FOR EACH ROW
BEGIN
    INSERT INTO Employee_Audit
    (
        emp_id,
        action_type,
        new_salary,
        action_date
    )
    VALUES
    (
        NEW.emp_id,
        'INSERT',
        NEW.salary,
        NOW()
    );
END $$

DELIMITER ;

-- =========================================
-- 5. TRIGGER FOR UPDATE
-- =========================================

DELIMITER $$

CREATE TRIGGER trg_employee_update
AFTER UPDATE ON Employees
FOR EACH ROW
BEGIN
    INSERT INTO Employee_Audit
    (
        emp_id,
        action_type,
        old_salary,
        new_salary,
        action_date
    )
    VALUES
    (
        OLD.emp_id,
        'UPDATE',
        OLD.salary,
        NEW.salary,
        NOW()
    );
END $$

DELIMITER ;

-- =========================================
-- 6. TRIGGER FOR DELETE
-- =========================================

DELIMITER $$

CREATE TRIGGER trg_employee_delete
AFTER DELETE ON Employees
FOR EACH ROW
BEGIN
    INSERT INTO Employee_Audit
    (
        emp_id,
        action_type,
        old_salary,
        action_date
    )
    VALUES
    (
        OLD.emp_id,
        'DELETE',
        OLD.salary,
        NOW()
    );
END $$

DELIMITER ;

