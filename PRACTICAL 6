-- =========================================
-- 8. CURSOR FOR SALARY INCREMENT
-- =========================================

DELIMITER $$

CREATE PROCEDURE increment_it_salary()
BEGIN

    DECLARE done INT DEFAULT FALSE;
    DECLARE v_emp_id INT;
    DECLARE v_salary DECIMAL(10,2);

    DECLARE emp_cursor CURSOR FOR
    SELECT emp_id, salary
    FROM Employees
    WHERE department = 'IT';

    DECLARE CONTINUE HANDLER
    FOR NOT FOUND SET done = TRUE;

    OPEN emp_cursor;

    read_loop: LOOP

        FETCH emp_cursor
        INTO v_emp_id, v_salary;

        IF done THEN
            LEAVE read_loop;
        END IF;

        UPDATE Employees
        SET salary = v_salary * 1.10
        WHERE emp_id = v_emp_id;

    END LOOP;

    CLOSE emp_cursor;

END $$

DELIMITER ;

-- =========================================
-- 9. EXECUTE CURSOR PROCEDURE
-- =========================================

CALL increment_it_salary();

-- =========================================
-- 10. DISPLAY TABLES
-- =========================================

